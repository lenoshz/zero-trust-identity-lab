# ═══════════════════════════════════════════════════════
# Zero Trust Identity Lab — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All secrets are configured here — never hardcode them
# in config files or application code.
# ═══════════════════════════════════════════════════════

# ── PostgreSQL (Keycloak Database) ──
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# ── Keycloak (Identity Provider) ──
KC_ADMIN=admin
KC_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin_password

# ── OpenBao (Secrets Management) ──
OPENBAO_DEV_ROOT_TOKEN_ID=CHANGE_ME_openbao_root_token
OPENBAO_ADDR=http://openbao:8200

# ── Flask Demo Application ──
FLASK_SECRET_KEY=CHANGE_ME_flask_secret_key
FLASK_KEYCLOAK_CLIENT_ID=flask-demo-app
FLASK_KEYCLOAK_CLIENT_SECRET=CHANGE_ME_keycloak_client_secret
FLASK_KEYCLOAK_REALM=zero-trust-realm
FLASK_OPENBAO_ADDR=http://openbao:8200
FLASK_OPENBAO_TOKEN=CHANGE_ME_openbao_token

# ── Elasticsearch & Kibana ──
ELASTIC_PASSWORD=CHANGE_ME_elastic_password
KIBANA_PASSWORD=CHANGE_ME_kibana_password

# ── Domain ──
DOMAIN=localhost
